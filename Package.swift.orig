// swift-tools-version:6.0
// WASM-only Package.swift - only library products, no executables
import PackageDescription

let package = Package(
    name: "Blitz3DCompiler",
    products: [
        // Only libraries for WASM build
        .library(
            name: "blitz3d-engine",
            targets: ["Blitz3DEngineWASM"]
        ),
        .library(
            name: "Blitz3DCompiler",
            targets: ["Blitz3DCompiler"]
        ),
    ],
    dependencies: [
        // Use 0.19.2 - last version before BridgeJS plugin was added
        // BridgeJS requires SwiftSyntax which can't compile for WASM
        .package(url: "https://github.com/swiftwasm/JavaScriptKit.git", exact: "0.19.2")
    ],
    targets: [
        .target(
            name: "Blitz3DEngineWASM",
            dependencies: [
                "Blitz3DEngine"
            ],
            path: "Tools/engine-wasm",
            exclude: []
        ),
        .target(
            name: "Blitz3DEngine",
            dependencies: [
                .product(name: "JavaScriptKit", package: "JavaScriptKit", condition: .when(platforms: [.wasi, .linux]))
            ],
            path: "Sources/Blitz3DEngine",
            exclude: [
                "AGENTs.md",
                "Banks/AGENTs.md",
                "Graphics/AGENTs.md",
                "Parsers/AGENTs.md",
                "Physics/AGENTs.md",
                "Utils/AGENTs.md",
                "SceneGraph/AGENTs.md",
                "Renderer/AGENTs.md",
            ]
        ),
        .target(
            name: "Blitz3DCompiler",
            dependencies: [],
            path: "Sources/Compiler",
            exclude: [
                "CodeGen/REFACTORING_PLAN.md",
                "IR/PLACEHOLDER.md",
                "AGENTs.md",
                "AST/AGENTs.md",
                "CodeGen/AGENTs.md",
                "IR/AGENTs.md",
                "Lexer/AGENTs.md",
                "Lowering/AGENTs.md",
                "Parser/AGENTs.md",
                "Preprocessor/AGENTs.md",
            ]
        ),
    ]
)
