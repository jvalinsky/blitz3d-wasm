      "node_type": "outcome",
      "title": "MapSystem --use-ir emits invalid WASM: validator reports drop underflows, call arg stack empties, i32/f32 mismatches, block/return result mismatches",
      "description": null,
      "status": "pending",
      "created_at": "2026-01-26T15:33:12.934601-05:00",
      "updated_at": "2026-01-26T15:33:12.934601-05:00",
